<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kjweb.legacy.domain.mapper.BoardLegacyMapper">
    <resultMap id="BoardLegacyResultMap" type="BoardLegacy">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findRecentBoards" resultMap="BoardLegacyResultMap">
        select id, title, content, created_at
        from legacy_board
        order by id desc
    </select>

    <select id="findById" parameterType="long" resultMap="BoardLegacyResultMap">
        select id, title, content, created_at
        from legacy_board
        where id = #{id}
    </select>
</mapper>
