<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Settlements</title></head><body><h1>Session Settlement Lab</h1><nav><a href="${pageContext.request.contextPath}/ops">Ops</a> | <a href="${pageContext.request.contextPath}/file-import">File Import</a></nav><h2>Direct Insert</h2><form method="post" action="${pageContext.request.contextPath}/settlements/direct"><input name="vendorCode" placeholder="vendorCode"><input name="amount" placeholder="amount"><input name="businessDate" placeholder="YYYY-MM-DD"><button>Insert Direct</button></form><h2>Session Workbox</h2><form method="post" action="${pageContext.request.contextPath}/settlements/session/add"><input name="vendorCode" placeholder="vendorCode"><input name="amount" placeholder="amount"><input name="businessDate" placeholder="YYYY-MM-DD"><button>Add To Session</button></form><form method="post" action="${pageContext.request.contextPath}/settlements/session/commit"><button>Commit Session Items</button></form><ul><c:forEach var="item" items="${workItems}"><li>${item.vendorCode} / ${item.amount} / ${item.businessDate}</li></c:forEach></ul><h2>Settlements</h2><table border="1"><tr><th>ID</th><th>Vendor</th><th>Amount</th><th>Date</th><th>Status</th></tr><c:forEach var="row" items="${settlements}"><tr><td>${row.id}</td><td>${row.vendorCode}</td><td>${row.amount}</td><td>${row.businessDate}</td><td>${row.status}</td></tr></c:forEach></table></body></html>